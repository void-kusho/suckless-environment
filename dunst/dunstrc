[global]
    monitor = 0
    follow = mouse

    width = 300
    height = (0, 300)
    origin = top-right
    offset = (10, 50)

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12

    frame_width = 2
    frame_color = "#7aa2f7"
    separator_color = frame

    sort = yes

    font = Iosevka Nerd Font 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center

    show_age_threshold = 60
    ellipsize = middle

    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    sticky_history = yes
    history_length = 20

    corner_radius = 8

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1a1b26"
    foreground = "#a9b1d6"
    frame_color = "#565f89"
    timeout = 5

[urgency_normal]
    background = "#1a1b26"
    foreground = "#a9b1d6"
    frame_color = "#7aa2f7"
    timeout = 10

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
