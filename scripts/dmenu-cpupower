#!/bin/sh
# dmenu-cpupower - CPU governor selector using dmenu
# Requires cpupower and polkit for privilege escalation

current=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "unknown")

selected=$(printf 'performance\nbalanced\neconomy\n' | dmenu -p "cpu: $current" -l 3 "$@")

[ -z "$selected" ] && exit 0

case "$selected" in
	performance) governor="performance" ;;
	balanced)    governor="schedutil" ;;
	economy)     governor="powersave" ;;
	*)           exit 1 ;;
esac

pkexec cpupower frequency-set -g "$governor"
